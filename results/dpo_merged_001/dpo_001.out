import math

def largest_triangle(a, b):
    """
    Finds the largest triangle that can be inscribed in an ellipse given its semi-major axis `a` and semi-minor axis `b`.
    
    Parameters:
    a (float): Semi-major axis of the ellipse.
    b (float): Semi-minor axis of the ellipse.
    
    Returns:
    tuple: The coordinates of the vertices of the largest inscribed triangle.
    """
    # Calculate the eccentricity of the ellipse
    eccentricity = math.sqrt(1 - b**2/a**2)
    
    # Define the vertices of the triangle
    vertex1 = (a * math.cos(math.radians(30)), b * math.sin(math.radians(30)))
    vertex2 = (a * math.cos(math.radians(60)), b * math.sin(math.radians(60)))
    vertex3 = (a * math.cos(math.radians(90)), b * math.sin(math.radians(90)))
    
    # Check if the triangle is inscribed in the ellipse
    if eccentricity > 1 or eccentricity < 0:
        return None  # Invalid ellipse, no triangle can be inscribed
    
    # Sort the vertices to find the largest triangle
    vertices = sorted([vertex1, vertex2, vertex3])
    
    # Calculate the area of the triangle using the shoelace formula
    area = abs(sum(vertex1[i] * vertex2[i + 1] for i in range(len(vertices)) - 
                sum(vertex1[i] * vertex2[i] for i in range(len(vertices)) - 1) +
                sum(vertex1[i] * vertex3[i + 1] for i in range(len(vertices)) - 2) -
                sum(vertex1[i] * vertex3[i] for i in range(len(vertices)) - 2) /
                2)
    
    # Return the vertices of the largest triangle
    return vertices, area
assert largest_triangle(4,2)==10.392304845413264
assert largest_triangle(5,7)==4.639421805988064
assert largest_triangle(9,1)==105.2220865598093
