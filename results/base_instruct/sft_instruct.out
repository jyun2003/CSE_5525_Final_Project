def find_Min(arr, low, high):
    """
    This function finds the minimum element in a sorted and rotated array.

    Args:
        arr (list): A sorted and rotated array.
        low (int): The starting index of the array.
        high (int): The ending index of the array.

    Returns:
        int: The minimum element in the array.
    """
    if low >= high:
        # If the array is empty or only contains one element, return that element
        return arr[low] if low < len(arr) else None

    # Find the pivot element (the element that is not in its correct position)
    pivot = find_min_pivot(arr, low, high)

    # Partition the array around the pivot element
    left = find_min_pivot(arr, low, pivot - 1)
    right = find_min_pivot(arr, pivot + 1, high)

    # Return the minimum element in the array
    return min(left, right)


def find_min_pivot(arr, low, high):
    """
    This function finds the minimum element in a subarray.

    Args:
        arr (list): A sorted and rotated array.
        low (int): The starting index of the subarray.
        high (int): The ending index of the subarray.

    Returns:
        int: The minimum element in the subarray.
    """
    if low >= high:
        # If the subarray is empty, return None
        return None

    # Find the pivot element (the element that is not in its correct position)
    pivot = find_min_pivot(arr, low, high - 1)

    # If the pivot element is the minimum element, return it
    if arr[pivot] == arr[low]:
        return arr[pivot]

    # If the pivot element is the maximum element, return the minimum element
    if arr[pivot] == arr[high]:
        return arr[pivot]

