def common_in_nested_lists(nestedlist):
    def flatten(lst):
        return [item for sublist in lst for item in flatten(sublist)]

    def find_common_elements(lst1, lst2):
        return [item for sublist1 in lst1 for item in flatten(sublist1) if item in lst2]

    def flatten_nested(lst):
        return [item for sublist in lst for item in flatten_nested(sublist)]

