def extract_elementwise_and_tuples(def, tuples):
    def extract_elementwise(tup):
        return tuple(map(lambda x: x if isinstance(x, tuple) else x, tup))

    def extract_tuples(tup):
        return tuple(map(lambda x: x if isinstance(x, tuple) else x, tup))

    def extract_elementwise_and_tuples(def, tuples):
        def_tuple = extract_elementwise(def)
        tuples_tuple = extract_tuples(tuples)
        return def_tuple, tuples_tuple

