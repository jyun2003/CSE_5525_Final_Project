def extract_elementwise_and_tuples(def, tuples):
    def extract_elementwise(tup):
        return tuple(map(lambda x: x, tup))
    def extract_tuples(tup):
        return tuple(tup)
    return extract_elementwise(def), extract_tuples(tuples)
